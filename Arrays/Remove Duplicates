class Solution {
public:
    int removeDuplicates(vector<int>& nums) {
        int ptr=1;
        int current=0;
        for (int i=1;i<nums.size();i++){
            if(nums[i]==nums[current]){
                continue;
            }
            else{
                current=i;
                nums[ptr]=nums[current];
                ptr++;
            }
            }

           return ptr; 
    }
    
};
